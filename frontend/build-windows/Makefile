	$(MAKE) $(MAKESILENT) -f CMakeFiles\Hotel_Management.dir\build.make CMakeFiles/Hotel_Management.dir/frontend.cpp.s
.PHONY : frontend.cpp.s

main.obj: main.cpp.obj
.PHONY : main.obj

# target to build an object file
main.cpp.obj:
	$(MAKE) $(MAKESILENT) -f CMakeFiles\Hotel_Management.dir\build.make CMakeFiles/Hotel_Management.dir/main.cpp.obj
.PHONY : main.cpp.obj

main.i: main.cpp.i
.PHONY : main.i

# target to preprocess a source file
main.cpp.i:
	$(MAKE) $(MAKESILENT) -f CMakeFiles\Hotel_Management.dir\build.make CMakeFiles/Hotel_Management.dir/main.cpp.i
.PHONY : main.cpp.i

main.s: main.cpp.s
.PHONY : main.s

# target to generate assembly for a file
main.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles\Hotel_Management.dir\build.make CMakeFiles/Hotel_Management.dir/main.cpp.s
.PHONY : main.cpp.s

